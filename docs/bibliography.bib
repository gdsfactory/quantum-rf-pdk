@article{gonzalezDesignFabricationInterdigital2015,
  title = {Design and {{Fabrication}} of {{Interdigital Nanocapacitors Coated}} with {{HfO2}}},
  author = {Gonz\'{a}lez, Gabriel and {Kolosovas-Machuca}, Eleazar Samuel and {L\'{o}pez-Luna}, Edgar and {Hern\'{a}ndez-Arriaga}, Heber and Gonz\'{a}lez, Francisco Javier},
