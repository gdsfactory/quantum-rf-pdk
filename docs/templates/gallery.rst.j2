PCells Gallery
==============

.. grid:: 2 3 3 4
   :gutter: 3

{% for item in items %}
   .. grid-item-card:: {{ item.name }}
      :link: cells.html#qpdk.cells.{{ item.name }}
      :text-align: center
{%     if item.name not in skip_plot %}

      .. plot::
         :height: 200px
         :width: 250px

         from qpdk import cells, PDK

         PDK.activate()
         c = cells.{{ item.name }}({{ item.kwargs }}).copy()
         c.draw_ports()
         c.plot()
{%     endif %}

{% endfor %}
